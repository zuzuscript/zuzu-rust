#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if [ "${ZUZULIB+x}" = x ]; then
	export ZUZULIB="$root/stdlib/test-modules:$root/modules:$root/stdlib/modules:$ZUZULIB"
else
	export ZUZULIB="$root/stdlib/test-modules:$root/modules:$root/stdlib/modules"
fi

exec cargo run --quiet --manifest-path "$root/Cargo.toml" --bin zuzu-rust -- "$@"
